{
  "manifest_version": 3,
  "name": "Selector Copy",
  "version": "0.1.0",
  "description": "指定した XPath にマッチする要素のテキストをコピーする。コピー設定(preset)を複数管理できる。",
  "permissions": ["storage", "scripting", "activeTab"],
  "action": {
    "default_title": "Selector Copy",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html"
}
